# Copy to .env.local. Used by Next.js server actions.
# Next.js server actions read these via process.env.NEXT_PUBLIC_VAR_NAME.

# The Cat API (images)
CAT_API_URL=https://api.thecatapi.com
CAT_API_KEY=your-api-key

# Backend APIs (when running full stack locally)
GO_API_URL=http://localhost:8001
JAVA_API_URL=http://localhost:8002
NODE_API_URL=http://localhost:8003
PYTHON_API_URL=http://localhost:8004
